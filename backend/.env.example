# ─────────────────────────────────────────────
#  COPIE ESTE ARQUIVO PARA .env E PREENCHA
#  cp .env.example .env
# ─────────────────────────────────────────────

# Servidor
PORT=5000
NODE_ENV=production

# Banco de dados PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=SuaSenhaAqui123!
POSTGRES_DB=cartorio_db
DB_HOST=postgres
DB_PORT=5432

# JWT — troque por uma string longa e aleatória
JWT_SECRET=troque-por-string-aleatoria-longa-aqui-abc123

# CORS — IP ou domínio do servidor (onde o frontend vai rodar)
CORS_ORIGIN=http://SEU_IP_AQUI:3001

# URL da API — mesmo IP, porta do backend
REACT_APP_API_URL=http://SEU_IP_AQUI:5000/api

# SMTP — email para envio automático (Usucapião)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=seuemail@gmail.com
SMTP_PASS=senha-de-app-gmail

# Porta do frontend (padrão 3001)
FRONTEND_PORT=3001

# Porta do backend (padrão 5000)
BACKEND_PORT=5000
