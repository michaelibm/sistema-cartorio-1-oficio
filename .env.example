# Copie este arquivo para .env e ajuste os valores.
# NUNCA faça commit do arquivo .env

# Banco de dados (Postgres)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=troque_esta_senha
POSTGRES_DB=cartorio_db
POSTGRES_PORT=5432

# Backend
NODE_ENV=production
BACKEND_PORT=5000

# ATENÇÃO: use um segredo forte em produção
JWT_SECRET=troque_este_jwt_secret

# Liberação de CORS para o frontend (ajuste conforme seu ambiente)
FRONTEND_PORT=3000
CORS_ORIGIN=http://localhost:3000

# URL usada pelo backend para conectar no Postgres (dentro da rede do docker)
DATABASE_URL=postgresql://postgres:troque_esta_senha@postgres:5432/cartorio_db

# Frontend (URL da API acessível do seu navegador)
REACT_APP_API_URL=http://localhost:5000/api
